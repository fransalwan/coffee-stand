# Python virtual env (jika ada scripting)
venv/
env/

# Backup files
*.bak
*.backup
*.orig

# ============================================
# Project Specific
# ============================================
# Postman local history (jika disimpan di repo)
postman_history/

# Local development scripts
dev-scripts/

# ============================================
# IMPORTANT: Files yang HARUS di-commit
# ============================================
# .env.example -> WAJIB di-commit sebagai template
# go.mod & go.sum -> WAJIB di-commit untuk dependency management
# Semua file *.go -> WAJIB di-commit
# README.md -> WAJIB di-commit
# postman_collection.json -> WAJIB di-commit