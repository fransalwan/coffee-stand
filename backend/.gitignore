# Binary & Build Artifacts
# ============================================
# Binary hasil compile (Golang)
/main
/backend
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool
*.out
*.cover

# Dependency directory
/vendor/

# Build output directory
/build/
/dist/

